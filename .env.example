# =============================================================================
# Exemplo de variáveis de ambiente — copie para .env e preencha os valores
# NÃO commite o .env (já está no .gitignore)
# =============================================================================

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_chunks

# --- Pipeline (opcionais — sobrescrevem os defaults do Makefile/scripts) ---
# BATCH_SIZE=80
# CONCURRENCY=4
# WORKERS=8

# --- Paths (opcionais — padrão é artifacts/ na raiz do repo) ---
# ARTIFACTS_DIR=artifacts
